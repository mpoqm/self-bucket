{
  "version": "9.0.3",
  "description": "A simple disk benchmark software with Aoi themed UI",
  "homepage": "https://crystalmark.info/en/software/crystaldiskmark/",
  "license": "BSD-3-Clause",
  "url": "https://sourceforge.net/projects/crystaldiskmark/files/9.0.3/CrystalDiskMark9_0_3Aoi.zip",
  "hash": "md5:a4ba5f183bf2fa8bc7005c1fe78e61e5",
  "architecture": {
    "64bit": {
      "bin": [
        [
          "DiskMark64A.exe",
          "DiskMark"
        ]
      ],
      "shortcuts": [
        [
          "DiskMark64A.exe",
          "CrystalDiskMark Aoi Edition"
        ]
      ]
    },
    "32bit": {
      "bin": [
        [
          "DiskMark32A.exe",
          "DiskMark"
        ]
      ],
      "shortcuts": [
        [
          "DiskMark32A.exe",
          "CrystalDiskMark Aoi Edition"
        ]
      ]
    },
    "arm64": {
      "bin": [
        [
          "DiskMarkA64A.exe",
          "DiskMark"
        ]
      ],
      "shortcuts": [
        [
          "DiskMarkA64A.exe",
          "CrystalDiskMark Aoi Edition"
        ]
      ]
    }
  },
  "persist": [
    "DiskMark32A.ini",
    "DiskMark64A.ini",
    "DiskMarkA64A.ini"
  ],
  "checkver": {
    "sourceforge": "crystaldiskmark",
    "regex": "([\\d.a-zA-Z]+)/CrystalDiskMark.*Aoi\\.zip"
  },
  "autoupdate": {
    "url": "https://sourceforge.net/projects/crystaldiskmark/files/$version/CrystalDiskMark$underscoreVersionAoi.zip"
  }
}
