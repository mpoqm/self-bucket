          "CrystalDiskMark Shizuku Edition"
        ]
      ]
    },
    "32bit": {
      "bin": [
        [
          "DiskMark32.exe",
          "DiskMark"
        ]
      ],
      "shortcuts": [
        [
          "DiskMark32.exe",
          "CrystalDiskMark Shizuku Edition"
        ]
      ]
    },
    "arm64": {
      "bin": [
        [
          "DiskMarkA64.exe",
          "DiskMark"
        ]
      ],
      "shortcuts": [
        [
          "DiskMarkA64.exe",
          "CrystalDiskMark Shizuku Edition"
        ]
      ]
    }
  },
  "persist": [
    "DiskMark32.ini",
    "DiskMark64.ini",
    "DiskMarkA64.ini"
  ],
  "checkver": {
    "sourceforge": "crystaldiskmark",
    "regex": "([\\d.a-zA-Z]+)/CrystalDiskMark.*Shizuku\\.zip"
  },
  "autoupdate": {
